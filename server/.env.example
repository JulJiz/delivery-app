PORT=5050

# Supabase Postgres connection string.
# Recomendado para este proyecto local: usar el "Session pooler" desde Connect.
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Cambiar a "disable" solo si el entorno no lo requiere.
SUPABASE_DB_SSL=require
